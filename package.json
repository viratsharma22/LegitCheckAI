    },
    "directories": {
      "output": "dist-electron"
    }
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^4.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
